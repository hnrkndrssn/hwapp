step "build-info-test" {
    name = "Build Info Test"
    properties = {
        Octopus.Action.TargetRoles = "web"
    }

    action {
        properties = {
            Octopus.Action.RunOnServer = "false"
            Octopus.Action.Template.Id = "ActionTemplates-61"
            Octopus.Action.Template.Version = "1"
            PackageId = "hwapp"
        }
        worker_pool_variable = ""
    }
}

step "run-a-script" {
    name = "Run a Script"

    action {
        action_type = "Octopus.Script"
        properties = {
            Octopus.Action.GitRepository.Source = "External"
            Octopus.Action.Script.ScriptFileName = "scripts/hello_world.ps1"
            Octopus.Action.Script.ScriptSource = "GitRepository"
            OctopusUseBundledTooling = "False"
        }
        worker_pool = "default-worker-pool"

        git_dependencies {
            default_branch = "main"
            git_credential_id = "GitCredentials-21"
            git_credential_type = "Library"
            repository_uri = "https://github.com/hnrkndrssn/HwApp.git"
        }
    }
}